NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_ENV=development
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
SANITY_REVALIDATE_SECRET=

# SANITY CMS
# use current date (YYYY-MM-DD) to target the latest API version
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-18
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=development
SANITY_API_READ_TOKEN=

# GOOGLE REVIEWS (OPTIONAL)
# Default behavior is demo data unless explicitly set to "google"
GOOGLE_REVIEWS_DATA_SOURCE=demo
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_LANGUAGE=en-GB

# GOOGLE MAPS (OPTIONAL)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
